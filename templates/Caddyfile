# Headscale Caddyfile 配置模板 (Let's Encrypt 自动证书)
# 使用前请将 YOUR_DOMAIN_HERE 和 YOUR_PORT_HERE 替换为实际值

YOUR_DOMAIN_HERE:YOUR_PORT_HERE {
    # 自动申请公信证书
    tls {
        # 如果需要，这里可以填入你的邮箱
        # email your-email@example.com
    }

    reverse_proxy 127.0.0.1:8080 {
        # 关键：禁用缓冲，支持长轮询 (等同于 nginx 的 proxy_buffering off)
        flush_interval -1

        transport http {
            read_timeout 600s
            write_timeout 600s
        }

        header_up Host {host}
        header_up Connection ""
    }
}
